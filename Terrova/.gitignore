# ============================================================================
# Next.js / Frontend
# ============================================================================
/node_modules
/.next/
/out/
/build
next-env.d.ts
*.tsbuildinfo

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Environment variables — NEVER commit secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*

# Vercel
.vercel

# ============================================================================
# Rust / Anchor Smart Contracts
# ============================================================================

# Cargo build artifacts (can be GB in size)
contracts/target/
contracts/programs/**/target/

# Anchor test ledger — local validator state, not needed in repo
contracts/.anchor/
.anchor/

# Anchor test node_modules
contracts/node_modules/

# Compiled .so binaries (regenerated by anchor build)
# Keep keypairs but not the binary
contracts/target/deploy/*.so
contracts/programs/**/target/deploy/*.so

# ============================================================================
# Solana
# ============================================================================

# Local wallet keypairs — NEVER commit private keys
# ~/.config/solana/id.json is referenced by path, don't commit it here

